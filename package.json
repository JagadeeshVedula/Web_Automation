{
  "name": "learning_typescript",
  "version": "1.0.0",
  "description": "Learning Typescript with playwright",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:regression": "playwright test --grep @regression --workers 6",
    "test:login": "playwright test --grep \"@login\""
  },
  "dependencies": {
    "playwright": "^1.60.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.2",
    "@types/winston": "^2.4.4"
  }
}
